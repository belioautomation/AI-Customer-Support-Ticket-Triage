      "parameters": {
        "jsCode": "const aiResponse = $json.text;\n\n// Remove markdown code blocks\nconst cleanJson = aiResponse\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\nconst result = JSON.parse(cleanJson);\n\nreturn [{\n  json: {\n    department: result.department,\n    priority: result.priority,\n    summary: result.summary\n  }\n}];"
      },
