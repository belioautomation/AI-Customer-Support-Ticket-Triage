        "text": "=Analyze this customer email and classify it.\n\nSender:\n{{ $json.From }}\n\nSubject:\n{{ $json.Subject }}\n\nEmail Content:\n{{ $json.snippet }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a support ticket classifier.  Analyze the email below.  If this is NOT a customer support request (newsletter, LinkedIn notification, marketing email, social media update, job alert, promotional content, automated notification), return:  {   \"department\":\"Ignore\",   \"priority\":\"Low\",   \"summary\":\"Non-support email\" }  Otherwise classify:  Departments: - Technical Support - Billing - Sales - General Inquiry  Priorities: - High - Medium - Low  Email:  From: {{ $json.From }}  Subject: {{ $json.Subject }}  Content: {{ $json.snippet }}  Return JSON only."
            }
          ]
        },
        "batching": {}
      },
